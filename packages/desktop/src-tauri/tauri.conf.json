{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "awsesh",
  "version": "1.0.0-beta.202601241326",
  "identifier": "ai.awsesh.desktop",
  "mainBinaryName": "default",
  "build": {
    "beforeDevCommand": "bun install && bun run dev",
    "beforeBuildCommand": "bun install && bun run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "AWSESH",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
