{
  "$schema": "https://json.schemastore.org/package.json",
  "name": "awsesh-workspace",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.1",
  "workspaces": ["packages/*"],
  "scripts": {
    "dev": "bun run --conditions=browser packages/awsesh/src/index.ts",
    "dev:watch": "bun --watch --conditions=browser packages/awsesh/src/index.ts",
    "start": "bun run --conditions=browser packages/awsesh/src/index.ts",
    "typecheck": "bun run --filter '*' typecheck",
    "test": "bun test"
  }
}
